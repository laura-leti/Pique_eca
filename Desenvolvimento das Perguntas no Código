# ==========================
# FUNÇÃO DO QUIZ
# ==========================

def executar_quiz(lista_perguntas):
    pontos = 0

    for pergunta in lista_perguntas:
        print("\n" + pergunta["pergunta"])

        for opcao in pergunta["opcoes"]:
            print(opcao)

        resposta = input("Resposta: ").upper()

        if resposta == pergunta["resposta"]:
            print("Correto!")
            pontos += 1
        else:
            print(f"Errado! Resposta correta: {pergunta['resposta']}")

    print(f"\nPontuação final: {pontos}/{len(lista_perguntas)}")

    if pontos >= len(lista_perguntas) * 0.7:
        print("🎉 Parabéns, Guardião! 🎉")
